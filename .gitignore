imgui.ini

# 压缩包
*.zip

# OS 缓存文件
.DS_Store
Thumbs.db

# =========================
# 5. Python & 模型相关
# =========================
# 字节码与代码检查缓存
__pycache__/
*.py[cod]
*$py.class
.ruff_cache/

# 虚拟环境目录
.venv/

# 深度学习模型权重 (避免提交几百 MB 的大文件)
*.pth
*.pt
*.ckpt
*.safetensors

